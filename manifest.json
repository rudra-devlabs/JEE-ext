{
  "manifest_version": 3,
  "name": "JEE Study Dashboard",
  "version": "1.0",
  "description": "Your personalized JEE preparation companion — countdown, question tracker, mistakes log, backlog manager, Pomodoro timer, notes, analytics, and more.",
  "permissions": ["storage", "unlimitedStorage", "activeTab", "alarms", "notifications"],
  "host_permissions": ["https://api.mistral.ai/*", "https://dashscope-intl.aliyuncs.com/*", "https://dashscope.aliyuncs.com/*", "https://api.groq.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "chrome_url_overrides": {
    "newtab": "dashboard.html"
  }
}
